{
  "info": {
    "name": "GPS Tracker - Users Module (Complete)",
    "description": "All user endpoints with test data and examples",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Setup - Create Organization with Admin",
      "item": [
        {
          "name": "Create Organization + Admin (Single Request)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {\n    var jsonData = pm.response.json();\n    pm.environment.set('organizationId', jsonData.data.organization._id);\n    pm.environment.set('adminUserId', jsonData.data.admin._id);\n    console.log('✅ Organization ID: ' + jsonData.data.organization._id);\n    console.log('✅ Admin User ID: ' + jsonData.data.admin._id);\n    console.log('✅ Admin Email: ' + jsonData.data.admin.email);\n}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superadmin_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "TechFlow Transport",
                  "type": "text"
                },
                {
                  "key": "organizationType",
                  "value": "transport",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "techflow@example.com",
                  "type": "text"
                },
                {
                  "key": "phone",
                  "value": "+91-9876543210",
                  "type": "text"
                },
                {
                  "key": "firstName",
                  "value": "Priya",
                  "type": "text"
                },
                {
                  "key": "lastName",
                  "value": "Singh",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "Admin@12345",
                  "type": "text"
                },
                {
                  "key": "address",
                  "value": "{\"addressLine\":\"123 Tech Park Road\",\"city\":\"Bangalore\",\"state\":\"Karnataka\",\"country\":\"India\",\"pincode\":\"560001\"}",
                  "type": "text"
                },
                {
                  "key": "geo",
                  "value": "{\"lat\":12.9716,\"lng\":77.5946,\"timezone\":\"Asia/Kolkata\"}",
                  "type": "text"
                },
                {
                  "key": "settings",
                  "value": "{\"speedAlert\":true,\"speedLimit\":100,\"idleTimeThreshold\":5}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/organization-admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "organization-admin"
              ]
            },
            "description": "Create Organization and Admin in single request\nAutomatically saves organizationId and adminUserId"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {\n    var jsonData = pm.response.json();\n    pm.environment.set('admin_token', jsonData.token);\n    console.log('✅ Admin logged in successfully');\n    console.log('✅ Token saved to admin_token');\n}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"techflow@example.com\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Login as Admin\nEmail: techflow@example.com\nPassword: Admin@12345"
          },
          "response": []
        },
        {
          "name": "Superadmin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {\n    var jsonData = pm.response.json();\n    pm.environment.set('superadmin_token', jsonData.token);\n    console.log('✅ Superadmin logged in successfully');\n}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@gps.com\",\n  \"password\": \"Superadmin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Login as Superadmin\n(Update email/password with your superadmin credentials)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Create Users",
      "item": [
        {
          "name": "Create Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {\n    var jsonData = pm.response.json();\n    pm.environment.set('managerId', jsonData.data._id);\n    console.log('✅ Manager created: ' + jsonData.data._id);\n}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superadmin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationId\": \"{{organizationId}}\",\n  \"firstName\": \"Rahul\",\n  \"lastName\": \"Verma\",\n  \"email\": \"rahul.verma@techflow.com\",\n  \"mobile\": \"+91-8765432101\",\n  \"passwordHash\": \"Manager@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/manager",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "manager"
              ]
            },
            "description": "Create a Manager user for the organization"
          },
          "response": []
        },
        {
          "name": "Create Driver User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {\n    var jsonData = pm.response.json();\n    pm.environment.set('driverId', jsonData.data._id);\n    console.log('✅ Driver user created: ' + jsonData.data._id);\n}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationId\": \"{{organizationId}}\",\n  \"firstName\": \"Arjun\",\n  \"lastName\": \"Kumar\",\n  \"email\": \"arjun.driver@techflow.com\",\n  \"mobile\": \"+91-9876543211\",\n  \"password\": \"Driver@123\",\n  \"driverId\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/driver",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "driver"
              ]
            },
            "description": "Create a Driver user account for login\nCan link to existing driver profile via driverId"
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Read Users",
      "item": [
        {
          "name": "Get All Admins (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superadmin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/admins?page=1&limit=10&search=priya",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "admins"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "search",
                  "value": "priya",
                  "description": "Search by firstName, lastName, email, or mobile",
                  "disabled": true
                }
              ]
            },
            "description": "Get all admin users with pagination and search\nOnly accessible by superadmin"
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Update Users",
      "item": [
        {
          "name": "Update User Details",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superadmin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Priya Kumar\",\n  \"lastName\": \"Singh Sharma\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{adminUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{adminUserId}}"
              ]
            },
            "description": "Update user details\nAllowed fields: firstName, lastName, email, mobile, status"
          },
          "response": []
        }
      ]
    },
    {
      "name": "6. Delete Users",
      "item": [
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superadmin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{managerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{managerId}}"
              ]
            },
            "description": "Delete a user\nOnly superadmin can delete users"
          },
          "response": []
        }
      ]
    },
