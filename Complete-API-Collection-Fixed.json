{
  "info": {
    "name": "GPS Tracker Complete API - Enhanced Token Management",
    "description": "Comprehensive GPS Tracker API collection with automated token management and all endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Enhanced Auth with better token handling",
          "if (pm.request.url.path.includes('login')) {",
          "    const response = pm.response.json();",
          "    const token = response.token || (response.data && response.data.token);",
          "    if (token) {",
          "        pm.collectionVariables.set('accessToken', token);",
          "        console.log('✅ Access Token auto-set in Collection Variables');",
          "        console.log('Token length: ' + token.length + ' chars');",
          "    } else {",
          "        console.log('❌ No token found in login response');",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Auto extract IDs from create/get responses to power subsequent requests",
          "if (pm.response.code >= 200 && pm.response.code < 300) {",
          "    const response = pm.response.json();",
          "    const path = pm.request.url.path.join('/');",
          "    const data = response.data || response;",
          "    ",
          "    if (data && data._id) {",
          "        const id = data._id;",
          "        if (path.includes('organizations')) pm.collectionVariables.set('orgId', id);",
          "        if (path.includes('users')) pm.collectionVariables.set('userId', id);",
          "        if (path.includes('drivers')) pm.collectionVariables.set('driverId', id);",
          "        if (path.includes('vehicle') && !path.includes('daily')) pm.collectionVariables.set('vehicleId', id);",
          "        if (path.includes('gpsdevice')) pm.collectionVariables.set('deviceId', id);",
          "        if (path.includes('devicemapping') || path.includes('mapping')) pm.collectionVariables.set('mappingId', id);",
          "        if (path.includes('alerts')) pm.collectionVariables.set('alertId', id);",
          "        if (path.includes('geofence')) pm.collectionVariables.set('geofenceId', id);",
          "        if (path.includes('poi')) pm.collectionVariables.set('poiId', id);",
          "        if (path.includes('notifications')) pm.collectionVariables.set('notificationId', id);",
          "        if (path.includes('permissions')) pm.collectionVariables.set('permissionId', id);",
          "        console.log('📝 Auto-extracted ID: ' + id + ' from path: ' + path);",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
